3.
Asynchronous value iteration also converges. Its updates are noisier because only one state is updated at a time,
but it still converges to the optimal value function.

def async_value_iteration(env, gamma=0.99, theta=1e-6):
    V = np.zeros(env.n_states())
    errors = []

    while True:
        s = np.random.randint(env.n_states())

        q = np.array([
            sum(p * (r + (0 if d else gamma * V[ns]))
                for p, ns, r, d in env.transitions(s, a))
            for a in range(env.n_actions())
        ])

        old = V[s]
        V[s] = q.max()

        errors.append(abs(old - V[s]))

        if errors[-1] < theta:
            break

    return V, errors

