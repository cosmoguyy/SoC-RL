Exploration Counter

visited_states = set()

states = [0, 1, 2, 1, 3, 4]

for state in states:

    visited_states.add(state)

print("Visited States:", visited_states)

print("Total Explored:", len(visited_states))




Epsilon-Greedy Exploration

import random

epsilon = 0.2

if random.random() < epsilon:

    action = random.choice(["Left", "Right", "Up", "Down"])

    print("Exploring:", action)

else:

    action = "Right"

    print("Exploiting:", action)



    
